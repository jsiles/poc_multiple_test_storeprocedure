# Database
DB_CONNECTION_STRING=sqlite:///test_cases.db

# Query to read test cases
TEST_CASES_QUERY=SELECT id, name, payload, expected_status, expected_contains FROM test_cases

# Endpoint config
ENDPOINT_URL=https://example.com/api/test
HTTP_METHOD=POST
HTTP_TIMEOUT=30

# Optional headers as JSON string
HTTP_HEADERS={"Content-Type":"application/json"}

# Output
RESULTS_DIR=results
RESULTS_BASENAME=bulk_test_results